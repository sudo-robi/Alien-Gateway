#!/usr/bin/env sh

echo "🚀 Running pre-push checks..."

# Validate branch naming convention
echo "🌿 Validating branch name..."
branch=$(git symbolic-ref --short HEAD)
branch_regex='^(feat|fix|docs|refactor|test|chore)\/[a-z0-9][a-z0-9\-]*[a-z0-9]$'

# Allow main, develop, staging to push freely
if [ "$branch" = "main" ] || [ "$branch" = "develop" ] || [ "$branch" = "staging" ]; then
    echo "✅ On protected branch '$branch' — skipping branch name check."
else
    if echo "$branch" | grep -qE "$branch_regex"; then
        echo "✅ Branch name '$branch' follows the naming convention."
    else
        echo "❌ Branch name '$branch' does NOT follow the naming convention."
        echo ""
        echo "✅ Expected format:  <prefix>/<short-description>"
        echo "   Allowed prefixes: feat, fix, docs, refactor, test, chore"
        echo "   Rules:            lowercase, hyphen-separated"
        echo ""
        echo "   Examples:"
        echo "     feat/merkle-root-anchoring"
        echo "     fix/address-lookup-panic"
        echo "     docs/contributing-guide"
        exit 1
    fi
fi

# Check for uncommitted changes
if ! git diff-index --quiet HEAD --; then
    echo "⚠️  Warning: You have uncommitted changes."
    echo "   Consider committing them before pushing."
fi

# Run Rust tests before push (gateway-contract)
if [ -d "gateway-contract" ]; then
    echo "🦀 Running Rust tests..."
    cd gateway-contract && export PATH="$HOME/.cargo/bin:$PATH" && cargo test
    if [ $? -ne 0 ]; then
        echo "❌ Rust tests failed. Fix them before pushing."
        exit 1
    fi
    cd ..
    echo "✅ Rust tests passed."
fi

echo "✅ Pre-push checks completed!"
