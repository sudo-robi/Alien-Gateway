#!/usr/bin/env sh

echo "🔍 Running pre-commit checks..."

# Check for console.log statements in staged JS/TS files
echo "🚫 Checking for console.log statements..."
staged_files=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|js|jsx)$' || true)

if [ -n "$staged_files" ]; then
    console_found=false
    for file in $staged_files; do
        if grep -n "console\.log" "$file" 2>/dev/null; then
            echo "❌ Found console.log in $file"
            console_found=true
        fi
    done
    if [ "$console_found" = true ]; then
        echo "❌ Remove console.log statements before committing."
        exit 1
    fi
    echo "✅ No console.log statements found."
fi

# Check for TODO/FIXME in staged files (Rust + JS/TS)
echo "📋 Checking for TODO/FIXME comments..."
all_staged=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|js|jsx|rs)$' || true)

    done
fi

# Check for TODO(phase-4) presence in Rust files (Security Warning)
echo "🛡️ Checking for Phase 4 stubs..."
phase4_staged=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.rs$' || true)

if [ -n "$phase4_staged" ]; then
    for file in $phase4_staged; do
        if grep -n "TODO(phase-4)" "$file" 2>/dev/null; then
            echo "🚨 WARNING: Found TODO(phase-4) in $file. This is a Phase 4 placeholder that MUST be replaced before mainnet deployment."
        fi
    done
fi

echo "✅ All pre-commit checks passed!"
